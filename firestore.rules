rules_version = '2';

// ============================================================
//  Firestore 보안 규칙 — 악센트 운영 관리 / NEANDER ERP
// ------------------------------------------------------------
//  설계 원칙:
//   1) AC'SCENT(매장) 컬렉션은 "기존 공개(테스트 모드) 동작"을 그대로
//      보존한다. 공개 매장 사이트와 관리자 페이지가 깨지면 안 되므로
//      비-neander 최상위 컬렉션은 read/write 를 종전대로 허용한다.
//      ⚠️ 단, 아래 catch-all 은 정규식으로 neander_* 를 "제외"한다.
//   2) neander_* 컬렉션은 "허용된 팀원"만 접근한다.
//      - 허용 기준: 로그인 + (부트스트랩 관리자 || neander_member_emails
//        에 본인 이메일 등록). 임의의 구글 계정 접근을 차단한다.
//
//  ⚠️ 이 파일을 게시(deploy)하기 전에 반드시:
//     1) neander_member_emails 백필 실행(기존 팀원 잠김 방지)
//     2) 클라이언트(members.ts lookup 유지) 배포
//     자세한 순서는 NEANDER_SECURITY_DEPLOY.md 참고.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- 공통 헬퍼 (neander 전용) ----------------------------
    function signedIn() {
      return request.auth != null;
    }
    function callerEmail() {
      // Google 로그인 토큰의 이메일 (소문자 가정 — gmail은 소문자로 발급)
      return signedIn() && request.auth.token.email != null
        ? request.auth.token.email
        : '';
    }
    // 부트스트랩 관리자 (NEXT_PUBLIC_NEANDER_ADMIN_EMAILS 와 동일하게 유지)
    function isAdmin() {
      return callerEmail() == 'nadr.jooyeon@gmail.com';
    }
    // 허용된 팀원: 관리자이거나, 이메일이 조회 컬렉션에 등록돼 있음
    function isAllowedMember() {
      return signedIn() && (
        isAdmin() ||
        exists(/databases/$(database)/documents/neander_member_emails/$(callerEmail()))
      );
    }

    // ---- 1) AC'SCENT(및 모든 비-neander) 컬렉션: 기존 공개 보존 ----
    //  {col} 은 최상위 컬렉션명(단일 세그먼트), {document=**} 는 그 이하 전체.
    //  neander_ 로 시작하면 여기서 허용하지 않고(아래 구체 규칙으로만 접근),
    //  그 외는 종전처럼 read/write 를 모두 허용한다(테스트 모드 유지).
    match /{col}/{document=**} {
      allow read, write: if !col.matches('neander_.*');
    }

    // ---- 2) neander_* : 허용된 팀원만 ------------------------

    // 이메일 → 팀원 매핑 조회 컬렉션 (규칙 게이트의 근거).
    // 클라이언트는 members.ts 에서만 갱신한다.
    match /neander_member_emails/{email} {
      allow read: if signedIn();
      allow write: if isAllowedMember();
    }

    // 메시지: 허용 팀원만 읽기/생성. 수정·삭제는 막는다(앱은 하지 않음).
    match /neander_messages/{id} {
      allow read: if isAllowedMember();
      allow create: if isAllowedMember();
      allow update, delete: if isAdmin();
    }

    // 채팅방
    match /neander_conversations/{id} {
      allow read, write: if isAllowedMember();
    }

    // 대화 읽음 시각
    match /neander_chat_reads/{id} {
      allow read, write: if isAllowedMember();
    }

    // 팀 공용 데이터(팀원/매출/일일업무/업무요청/스케줄/회의록)
    match /neander_members/{id}        { allow read, write: if isAllowedMember(); }
    match /neander_sales/{id}          { allow read, write: if isAllowedMember(); }
    match /neander_daily_tasks/{id}    { allow read, write: if isAllowedMember(); }
    match /neander_work_requests/{id}  { allow read, write: if isAllowedMember(); }
    match /neander_schedules/{id}      { allow read, write: if isAllowedMember(); }
    match /neander_meetings/{id}       { allow read, write: if isAllowedMember(); }
    match /neander_shortcuts/{id}      { allow read, write: if isAllowedMember(); }

    // 개발 협업 허브(/neander/dev): 기능·작업·타임라인·댓글 — 허용 팀원만
    match /neander_dev_features/{id}   { allow read, write: if isAllowedMember(); }
    match /neander_dev_tasks/{id}      { allow read, write: if isAllowedMember(); }
    match /neander_dev_activity/{id}   { allow read, write: if isAllowedMember(); }
    match /neander_dev_comments/{id}   { allow read, write: if isAllowedMember(); }
  }
}
